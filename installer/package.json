{
  "name": "@ijfw/install",
  "version": "0.4.0-rc.1",
  "description": "One-command installer for IJFW — the AI efficiency layer.",
  "type": "module",
  "bin": {
    "ijfw-install": "./dist/install.js",
    "ijfw-uninstall": "./dist/uninstall.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "esbuild src/install.js src/uninstall.js --bundle --platform=node --target=node18 --outdir=dist --format=esm --banner:js='#!/usr/bin/env node'",
    "test": "node --test test.js",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {},
  "devDependencies": {
    "esbuild": "^0.23"
  },
  "engines": { "node": ">=18" },
  "keywords": ["ijfw", "claude-code", "ai", "installer"],
  "license": "MIT",
  "author": "Sean Donahoe",
  "repository": { "type": "git", "url": "https://github.com/TradeCanyon/ijfw" }
}
